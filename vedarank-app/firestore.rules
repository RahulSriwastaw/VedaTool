// Add these rules to your existing vedatool Firestore rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // VedaRank Submissions - users can read/write their own, admins can read all
    match /vedarank_submissions/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || 
         exists(/databases/$(database)/documents/vedarank_admins/$(request.auth.uid)));
      allow delete: if request.auth != null && 
        exists(/databases/$(database)/documents/vedarank_admins/$(request.auth.uid));
    }

    // VedaRank Admins - only admins can read
    match /vedarank_admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
  }
}
